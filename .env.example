# ===========================================================================
# advac — environment configuration
# Copy this file to `.env` (or export the variables) before starting the app.
# Every variable is OPTIONAL — the app runs in a sensible dev mode without any.
# ===========================================================================

# Port the Express server listens on (default 3000)
PORT=3000

# Public base URL of the deployed app. Used to build magic links in emails.
# If unset, the server derives it from the incoming request.
APP_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Magic-link email delivery (server/email.js)
#
# Option A (default, zero-config): leave RESEND_API_KEY unset and the magic
#   link is printed to the server console — handy for local development.
# Option B: Resend (https://resend.com) — create an API key, verify a sending
#   domain, and set the two variables below.
# Option C: SendGrid / Nodemailer — see the commented alternatives in
#   server/email.js.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Immigration Advice Service <no-reply@example.com>"

# How long a magic link stays valid, in hours (default 168 = 7 days)
MAGIC_LINK_TTL_HOURS=168

# ---------------------------------------------------------------------------
# Google Drive integration (server/drive.js) — currently a STUB.
#
# The upload pipeline is fully wired; to go live you only need to:
#   1. Create a Google Cloud project, enable the Drive API
#   2. Create OAuth2 credentials and obtain a refresh token authorised for
#      the https://www.googleapis.com/auth/drive.file scope
#   3. Fill in the four values below and set GOOGLE_DRIVE_ENABLED=true
#   4. `npm install googleapis` (listed as an optional dependency)
# ---------------------------------------------------------------------------
GOOGLE_DRIVE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=
# Optional: Drive folder to upload into (defaults to the Drive root)
GOOGLE_DRIVE_FOLDER_ID=
